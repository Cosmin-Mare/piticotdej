# Firebase (client — public, safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Public site URL (robots.txt, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.piticotdej.ro

# Firebase App Check (optional — enable in Firebase Console first)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Dev only: register debug token in Firebase Console → App Check
NEXT_PUBLIC_APPCHECK_DEBUG_TOKEN=

# Firebase Admin (server only — keep secret; pick ONE option)
# Option A: individual fields from the service account JSON (recommended for .env.local)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Option B: full JSON on a single line (good for Vercel; do NOT paste multi-line JSON here)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Nightly Firestore backup bucket (default: {projectId}-firestore-backups)
FIREBASE_BACKUP_BUCKET=

# Maintainer contact for „Am nevoie de ajutor” button
NEXT_PUBLIC_MAINTAINER_EMAIL=contact@piticotdej.ro
NEXT_PUBLIC_MAINTAINER_PHONE=
